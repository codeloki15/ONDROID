# LocalLink Pro Server Configuration

# AI Provider (openai, ollama, mock)
AI_PROVIDER=mock

# OpenAI Configuration (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4

# Ollama Configuration (if AI_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Server Configuration
WS_HOST=0.0.0.0
WS_PORT=8765

# Bluetooth Configuration (Linux only)
BT_ENABLED=false
BT_CHANNEL=1

# Logging
LOG_LEVEL=INFO
